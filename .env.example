# Pagar.me (Stone) – Credenciais
# Copie este arquivo para .env e preencha com suas chaves
# Dashboard: https://dashboard.pagar.me

# Chave secreta do servidor (sk_test_... para sandbox, sk_live_... para produção)
PAGARME_SECRET_KEY=sk_test_SUA_CHAVE_AQUI

# Número do WhatsApp para notificações (apenas dígitos, com DDI)
WHATSAPP_NUMBER=5515XXXXXXXXX
# WhatsApp Cloud API (Official)
WHATSAPP_TOKEN=your_permanent_access_token
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_TEMPLATE_NAME=product_offer_button
